      "settings": {
        "custom_liquid": "<div class=\"career-form-wrap\">\n  <h2 class=\"career-title\">DISTRIBUTORS</h2>\n  <p class=\"career-sub\">\n    * Denotes mandatory fields\n  </p>\n\n  {% form 'contact', id: 'DistributorForm' %}\n\n<input type=\"hidden\" name=\"contact[to]\" value=\"mdfaraz2213@gmail.com\">\n\n    {% if form.posted_successfully? %}\n      <div class=\"career-success\">✅ Thank you! Your details have been submitted successfully.</div>\n    {% endif %}\n\n    {% if form.errors %}\n      <div class=\"career-error\">\n        ❌ Please fix the highlighted fields and try again.\n        {{ form.errors | default_errors }}\n      </div>\n    {% endif %}\n\n    <div class=\"career-grid\">\n\n      <!-- =========================\n        COMPANY INFORMATION\n      ========================= -->\n      <div class=\"section-title full\">COMPANY INFORMATION</div>\n\n      <div class=\"field\">\n        <label>Company Name *</label>\n        <input type=\"text\" name=\"contact[Company Name]\" placeholder=\"Company Name\" required>\n      </div>\n\n      <div class=\"field\">\n        <label>Annual Turnover (in Rs. Crores) For Last Financial Year *</label>\n        <input type=\"text\" name=\"contact[Annual Turnover - Last FY]\" placeholder=\"Enter the Annual Turn over\" required>\n      </div>\n\n      <div class=\"field\">\n        <label>State *</label>\n        <select name=\"contact[State]\" required>\n          <option value=\"\" disabled selected>Select State</option>\n          <option>Andhra Pradesh</option>\n          <option>Arunachal Pradesh</option>\n          <option>Assam</option>\n          <option>Bihar</option>\n          <option>Chhattisgarh</option>\n          <option>Goa</option>\n          <option>Gujarat</option>\n          <option>Haryana</option>\n          <option>Himachal Pradesh</option>\n          <option>Jharkhand</option>\n          <option>Karnataka</option>\n          <option>Kerala</option>\n          <option>Madhya Pradesh</option>\n          <option>Maharashtra</option>\n          <option>Manipur</option>\n          <option>Meghalaya</option>\n          <option>Mizoram</option>\n          <option>Nagaland</option>\n          <option>Odisha</option>\n          <option>Punjab</option>\n          <option>Rajasthan</option>\n          <option>Sikkim</option>\n          <option>Tamil Nadu</option>\n          <option>Telangana</option>\n          <option>Tripura</option>\n          <option>Uttar Pradesh</option>\n          <option>Uttarakhand</option>\n          <option>West Bengal</option>\n          <option>Delhi</option>\n          <option>Chandigarh</option>\n          <option>Jammu & Kashmir</option>\n          <option>Ladakh</option>\n          <option>Puducherry</option>\n        </select>\n      </div>\n\n      <div class=\"field\">\n        <label>Collaboration / Joint Venture / Licensing Etc. Distributor Name, Location And Other Details *</label>\n        <textarea name=\"contact[Collaboration-JV-Licensing Details]\" rows=\"4\" placeholder=\"Enter the Details\" required></textarea>\n      </div>\n\n      <!-- =========================\n        EMPLOYEE DETAILS\n      ========================= -->\n      <div class=\"section-title full\">EMPLOYEE DETAILS</div>\n\n      <div class=\"field\">\n        <label>Management *</label>\n        <input type=\"text\" name=\"contact[Management]\" placeholder=\"Enter the management information.\" required>\n      </div>\n\n      <div class=\"field\">\n        <label>Operational *</label>\n        <input type=\"text\" name=\"contact[Operational]\" placeholder=\"Enter the operational information.\" required>\n      </div>\n\n      <div class=\"field\">\n        <label>Companies worked with before *</label>\n        <input type=\"text\" name=\"contact[Companies Worked With Before]\" placeholder=\"Enter the Companies worked with before.\" required>\n      </div>\n\n      <div class=\"field\">\n        <label>Have you ever worked with Britannia before? If Yes, kindly provide us the details *</label>\n        <textarea name=\"contact[Worked With Britannia Before]\" rows=\"3\" placeholder=\"Enter the Britannia work information.\" required></textarea>\n      </div>\n\n      <!-- =========================\n        GENERAL INFORMATION\n      ========================= -->\n      <div class=\"section-title full\">GENERAL INFORMATION</div>\n\n      <div class=\"field\">\n        <label>Contact Person *</label>\n        <input type=\"text\" name=\"contact[Contact Person]\" placeholder=\"Enter the Contact Person.\" required>\n      </div>\n\n      <div class=\"field\">\n        <label>Phone *</label>\n        <input type=\"tel\" name=\"contact[Phone]\" placeholder=\"Enter the Phone information.\" required>\n      </div>\n\n      <div class=\"field\">\n        <label>Fax</label>\n        <input type=\"text\" name=\"contact[Fax]\" placeholder=\"Enter the Fax information.\">\n      </div>\n\n      <div class=\"field\">\n        <label>Mobile *</label>\n        <input type=\"tel\" name=\"contact[Mobile]\" placeholder=\"Enter the Mobile information.\" required>\n      </div>\n\n      <div class=\"field\">\n        <label>Email *</label>\n        <input type=\"email\" name=\"contact[email]\" placeholder=\"Enter the email Id.\" required>\n      </div>\n\n      <div class=\"field\">\n        <label>Website</label>\n        <input type=\"url\" name=\"contact[Website]\" placeholder=\"Enter the Website url\">\n      </div>\n\n      <div class=\"field\">\n        <label>Business Type *</label>\n        <input type=\"text\" name=\"contact[Business Type]\" placeholder=\"Enter the Business Type.\" required>\n      </div>\n\n      <div class=\"field\">\n        <label>Year of start of business *</label>\n        <input type=\"text\" name=\"contact[Year of Start of Business]\" placeholder=\"Enter the year of start of business.\" required>\n      </div>\n\n      <!-- Optional message (kept same style) -->\n      <div class=\"field full\">\n        <label>Additional Notes</label>\n        <textarea name=\"contact[body]\" rows=\"4\" placeholder=\"Any extra information...\"></textarea>\n      </div>\n\n    </div>\n\n    <button type=\"submit\" class=\"career-btn\">SUBMIT</button>\n\n  {% endform %}\n</div>\n\n<style>\n/* =========================\n   BASE CONTAINER\n========================= */\n.career-form-wrap{\n  max-width: 920px;\n  margin: 30px auto;\n  padding: 30px;\n  background: #fff;\n  border-radius: 18px;\n  border: 1px solid rgba(0,0,0,.08);\n  box-shadow: 0 10px 30px rgba(0,0,0,.06);\n}\n\n/* =========================\n   🔥 REMOVE ALL EXTRA LINES\n========================= */\n.career-form-wrap *,\n.career-form-wrap *::before,\n.career-form-wrap *::after{\n  border: none !important;\n  outline: none !important;\n  box-shadow: none !important;\n  background-image: none !important;\n}\n\n/* =========================\n   GRID & FIELDS\n========================= */\n.career-grid{\n  display: grid;\n  grid-template-columns: repeat(2, 1fr);\n  gap: 16px 18px;\n}\n\n.field{\n  display: flex;\n  flex-direction: column;\n}\n\n/* LABEL – NO BORDER AT ALL */\n.field label{\n  font-size: 13px;\n  font-weight: 700;\n  margin-bottom: 8px;\n  color: #111;\n}\n\n/* INPUTS – ONLY SINGLE BORDER */\n.field input,\n.field select,\n.field textarea{\n  width: 100%;\n  padding: 12px 14px;\n  border-radius: 12px;\n  border: 1px solid rgba(0,0,0,.2) !important;\n  font-size: 14px;\n  background: #fff !important;\n}\n\n/* TEXTAREA */\n.field textarea{\n  min-height: 120px;\n  resize: vertical;\n}\n\n/* FOCUS */\n.field input:focus,\n.field select:focus,\n.field textarea:focus{\n  border-color: rgba(0,0,0,.45) !important;\n}\n\n/* FULL WIDTH */\n.field.full{\n  grid-column: 1 / -1;\n}\n\n/* SECTION TITLES (only added like image) */\n.section-title{\n  grid-column: 1 / -1;\n  font-weight: 800;\n  font-size: 13px;\n  letter-spacing: .5px;\n  color: #c01919;\n  margin-top: 6px;\n}\n\n/* BUTTON */\n.career-btn{\n  width: 100%;\n  margin-top: 22px;\n  padding: 14px;\n  border-radius: 14px;\n  border: none;\n  font-size: 15px;\n  font-weight: 800;\n  cursor: pointer;\n  background: #111;\n  color: #fff;\n}\n\n.career-btn:hover{ opacity: .9; }\n\n/* SUCCESS / ERROR */\n.career-success{\n  background: #e9f8ee;\n  border: 1px solid #bfe7cb;\n  padding: 12px;\n  border-radius: 12px;\n  margin-bottom: 14px;\n}\n\n.career-error{\n  background: #fff1f1;\n  border: 1px solid #f2bcbc;\n  padding: 12px;\n  border-radius: 12px;\n  margin-bottom: 14px;\n}\n\n/* MOBILE */\n@media (max-width: 768px){\n  .career-form-wrap{ padding: 20px; }\n  .career-grid{ grid-template-columns: 1fr; }\n  .career-title{ font-size: 24px; }\n}\n</style>",
