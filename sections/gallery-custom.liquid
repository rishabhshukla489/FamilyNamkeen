{% schema %}
{
  "name": "Auto Gallery",
  "settings": [
    {
      "type": "text",
      "id": "file_prefix",
      "label": "Image Filename Prefix",
      "default": "gallery-"
    },
    {
      "type": "range",
      "id": "desktop_columns",
      "label": "Desktop Images Per Row",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 4
    },
    {
      "type": "range",
      "id": "mobile_columns",
      "label": "Mobile Images Per Row",
      "min": 1,
      "max": 3,
      "step": 1,
      "default": 2
    },
    {
      "type": "range",
      "id": "gap",
      "label": "Image Gap (px)",
      "min": 0,
      "max": 30,
      "step": 2,
      "default": 10
    }
  ],
  "presets": [
    {
      "name": "Auto Gallery"
    }
  ]
}
{% endschema %}

<style>
.gallery-wrapper-{{ section.id }} {
  display: grid;
  grid-template-columns: repeat({{ section.settings.mobile_columns }}, 1fr);
  gap: {{ section.settings.gap }}px;
}

@media screen and (min-width: 768px) {
  .gallery-wrapper-{{ section.id }} {
    grid-template-columns: repeat({{ section.settings.desktop_columns }}, 1fr);
  }
}

.gallery-wrapper-{{ section.id }} img {
  width: 100%;
  height: auto;
  display: block;
}
</style>

<div class="gallery-wrapper-{{ section.id }}">
  {% for file in shop.files %}
    {% if file.filename contains section.settings.file_prefix %}
      <div>
        <img 
          src="{{ file | file_url }}" 
          alt="Gallery Image"
          loading="lazy"
        >
      </div>
    {% endif %}
  {% endfor %}
</div>